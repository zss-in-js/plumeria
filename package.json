{
  "name": "plumeria-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "test-e2e/site",
    "docs"
  ],
  "author": "refirst",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "test": "jest",
    "dev": "cd docs && npm run dev",
    "dev:e2e": "cd test-e2e/site && npm run dev -- -p 4000",
    "test:e2e": "playwright test",
    "prettier": "prettier --write \"**/*.js\" \"**/*.ts\"",
    "prettier:report": "prettier --check \"**/*.js\" \"**/*.ts\"",
    "lint:report": "eslint --fix"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@plumeria/eslint-plugin": "workspace:^",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.13",
    "eslint": "^9.39.3",
    "jest": "^29.7.0",
    "next": "catalog:",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "prettier-plugin-insert-comma": "^1.1.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "turbo": "^2.8.13",
    "typescript": "5.9.2",
    "typescript-eslint": "^8.56.1"
  },
  "packageManager": "pnpm@10.24.0"
}
