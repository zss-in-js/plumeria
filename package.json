{
  "name": "plumeria-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "test-e2e/site",
    "docs"
  ],
  "author": "refirst",
  "license": "MIT",
  "scripts": {
    "build": "turbo run build --filter=./packages/*",
    "test": "jest --coverage",
    "dev": "cd docs && npm run dev",
    "dev:e2e": "cd test-e2e/site && npm run dev -- -p 4000",
    "test:e2e": "playwright test",
    "prettier": "prettier --write \"**/*.js\" \"**/*.ts\"",
    "prettier:report": "prettier --check \"**/*.js\" \"**/*.ts\"",
    "lint:report": "eslint --fix",
    "changeset:version": "node scripts/update-release-note.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@plumeria/eslint-plugin": "workspace:^",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "next": "catalog:",
    "oxlint": "1.67.0",
    "prettier": "^3.8.3",
    "prettier-plugin-insert-comma": "^1.1.7",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "turbo": "^2.9.16",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "packageManager": "pnpm@11.3.0"
}
