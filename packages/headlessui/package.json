{
  "name": "@plumeria/headlessui",
  "version": "14.1.2",
  "description": "Headless UI components wrapper for Plumeria based on Radix UI",
  "author": "Refirst 11",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "rimraf dist && tsc"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8"
  },
  "devDependencies": {
    "@plumeria/core": "workspace:^",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
