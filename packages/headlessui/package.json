{
  "name": "@plumeria/headlessui",
  "version": "15.0.0",
  "description": "Headless UI components wrapper for Plumeria based on Radix UI",
  "author": "Refirst 11",
  "license": "MIT",
  "funding": "https://github.com/sponsors/refirst11",
  "homepage": "https://plumeria.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zss-in-js/plumeria.git",
    "directory": "packages/headlessui"
  },
  "bugs": {
    "url": "https://github.com/zss-in-js/plumeria/issues"
  },
  "keywords": [
    "plumeria",
