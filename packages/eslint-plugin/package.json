{
  "name": "@plumeria/eslint-plugin",
  "version": "15.1.3",
  "description": "Plumeria ESLint plugin",
  "author": "Refirst 11",
  "license": "MIT",
  "funding": "https://github.com/sponsors/refirst11",
  "homepage": "https://plumeria.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zss-in-js/plumeria.git",
    "directory": "packages/eslint-plugin"
  },
  "bugs": {
    "url": "https://github.com/zss-in-js/plumeria/issues"
  },
  "keywords": [
    "plumeria",
    "eslint",
    "eslint-plugin",
    "oxlint",
    "lint",
    "css-in-js"
  ],
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./oxlint-plugin": "./oxlint-plugin.js"
  },
  "files": [
    "dist/",
    "oxlint-plugin.js",
    "oxlint.json"
  ],
  "bin": {
    "plumerialint": "bin/oxlint.js"
  },
  "scripts": {
    "build": "rimraf dist && pnpm cjs",
    "cjs": "tsc --project tsconfig.cjs.json"
  },
  "devDependencies": {
    "@types/eslint": "^9.6.1",
    "@types/estree": "^1.0.9",
    "@types/estree-jsx": "^1.0.5",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.60.0",
    "known-css-properties": "^0.37.0"
  }
}
